# ─────────────────────────────────────────────────────────────────
# SafeRoute Israel – Backend environment variables
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001

# Pikud HaOref (Home Front Command) alert feed
# Public endpoint – no auth required, but respect rate limits.
PIKUD_HAOREF_URL=https://www.oref.org.il/WarningMessages/alert/alerts.json

# GovMap WFS endpoint for Layer 417 (bomb shelters)
# Inspect GovMap network traffic to confirm the exact URL.
GOVMAP_WFS_URL=https://www.govmap.gov.il/govmap/api/layers/data

# GovMap layer identifier for public bomb shelters
GOVMAP_LAYER_ID=417

# Mobile client origin (for CORS)
MOBILE_ORIGIN=exp://localhost:8081

# Alert polling interval in milliseconds (2 000 = 2 s)
POLL_INTERVAL_MS=2000
