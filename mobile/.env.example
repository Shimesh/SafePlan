# ─────────────────────────────────────────────────────────────────
# SafeRoute Israel – Mobile environment variables
# Copy this file to .env and fill in your values before running.
# Expo reads vars prefixed with EXPO_PUBLIC_ into the JS bundle.
# Never commit real keys – this file is the template only.
# ─────────────────────────────────────────────────────────────────

# Google Maps / Directions API key
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Maps SDK for Android, Maps SDK for iOS, Directions API
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Backend base URL (change to your deployed URL in production)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# Enable mock scenario (set to "true" to auto-trigger emergency after 60s)
EXPO_PUBLIC_MOCK_MODE=false
